{
  "events": {
    "type": "Enriched"
    "format": { "type": "TSV" }
    "generateEnrichments": true
  }

  "output": {
    "type": "Kinesis"
    "streamName": "hooli-enriched"
    "region": "us-east-2"
  }

  "eventsPerPayload": {
    "min": 1
    "max": 1
  }

  "rate": {
    "eventsPerSecond": 2000
    "tickMillis": 500
  }
}
